{
  "ConnectionStrings": {
    // PostgreSQL connection string used by EF Core.
    "Icecold": "Host=localhost;Port=55432;Database=icecold;Username=icecold;Password=icecold"
  },
  "Icecold": {
    // Base URL embedded into .torrent webseed URLs and tracker announce URLs returned to clients.
    "PublicBaseUrl": "http://localhost:5038",
    // Required for all /api/* admin endpoints. Clients must supply this in the X-Icecold-Admin-Key header.
    // Intentionally absent here — provide via environment variable or secret in production.
    // In development, appsettings.Development.json sets this to "dev-admin-key".
    // "AdminApiKey": "",
    "Database": {
      // Run pending EF Core migrations automatically on startup. The production Compose file
      // enables this via ICECOLD_AUTO_MIGRATE. Set to false to manage migrations manually.
      "AutoMigrate": false
    },
    "Indexing": {
      // Number of parallel hashing workers that process the indexing queue. Min 1.
      "MaxConcurrency": 1,
      // Maximum number of pending indexing jobs held in memory before EnqueueAsync blocks. Min 1.
      "QueueCapacity": 10000
    },
    "Tracker": {
      // Recommended reannounce interval returned to clients, in seconds. (Default: 30 min)
      "AnnounceIntervalSeconds": 1800,
      // Minimum reannounce interval returned to clients, in seconds. (Default: 5 min)
      "MinAnnounceIntervalSeconds": 300,
      // Time after which a peer that has stopped announcing is removed from the in-memory store. (Default: 45 min)
      "PeerTimeoutSeconds": 2700,
      // Maximum number of peers returned in a single announce response.
      "MaxPeersReturned": 200
    },
    "PeerWire": {
      // Enable the upload-only TCP peer-wire seeding listener.
      "Enabled": false,
      // Local IP address to bind the listener. 0.0.0.0 listens on all interfaces.
      "BindAddress": "0.0.0.0",
      // TCP port to listen on for incoming peer connections.
      "ListenPort": 6881,
      // Public IP address advertised in tracker responses. Must be an IP address, not a hostname —
      // BitTorrent compact peer responses cannot carry DNS names. Required when Enabled is true.
      "AdvertisedIp": "",
      // Public port advertised in tracker responses. Can differ from ListenPort when behind NAT.
      "AdvertisedPort": 6881,
      // Maximum piece block size accepted from peers, in bytes. 16384 (16 KiB) is the BitTorrent standard.
      // Requests larger than MaxBlockLength + 1024 bytes are rejected.
      "MaxBlockLength": 16384,
      // Advertised as reqq in the extension handshake: the number of outstanding requests a peer may pipeline.
      "MaxOutstandingRequests": 8192,
      // Maximum number of concurrent peer connections. New connections are rejected once this is reached.
      "MaxConnections": 128,
      // Timeout for completing the BitTorrent or MSE/RC4 handshake before dropping the connection, in seconds.
      "HandshakeTimeoutSeconds": 15,
      // Timeout before an idle connection with no messages (including keepalives) is closed, in seconds.
      "IdleTimeoutSeconds": 120
    },
    // Named content sources. Multiple sources can be defined for separate hot/cold paths.
    // If omitted entirely, a default "local" source is created at {ContentRootPath}/data/files.
    "ContentSources": [
      {
        // Unique source identifier (case-insensitive). Used in indexing requests and stored with each torrent.
        "Name": "local",
        // Source type. Only "local" is implemented; S3 and HTTP sources are not yet available.
        "Type": "local",
        // Base directory for this source. Relative paths are resolved from the application content root.
        "RootPath": "./data/files"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
