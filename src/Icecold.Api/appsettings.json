{
  "ConnectionStrings": {
    "Icecold": "Host=localhost;Port=55432;Database=icecold;Username=icecold;Password=icecold"
  },
  "Icecold": {
    "PublicBaseUrl": "http://localhost:5038",
    "Database": {
      "AutoMigrate": false
    },
    "Indexing": {
      "MaxConcurrency": 1
    },
    "Tracker": {
      "AnnounceIntervalSeconds": 1800,
      "MinAnnounceIntervalSeconds": 300,
      "PeerTimeoutSeconds": 2700,
      "MaxPeersReturned": 200
    },
    "PeerWire": {
      "Enabled": false,
      "BindAddress": "0.0.0.0",
      "ListenPort": 6881,
      "AdvertisedIp": "",
      "AdvertisedPort": 6881,
      "MaxBlockLength": 16384,
      "MaxConnections": 128
    },
    "ContentSources": [
      {
        "Name": "local",
        "Type": "local",
        "RootPath": "./data/files"
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
